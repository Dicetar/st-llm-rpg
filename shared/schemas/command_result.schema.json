{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandResult",
  "type": "object",
  "required": [
    "turn_id",
    "results"
  ],
  "properties": {
    "turn_id": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failure",
              "noop"
            ]
          },
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": "string"
          },
          "applied_changes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "refresh_hints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "narration_context": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
