{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandRequest",
  "type": "object",
  "required": [
    "actor_id",
    "scene_id",
    "commands"
  ],
  "properties": {
    "actor_id": {
      "type": "string"
    },
    "scene_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "raw_text": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "dry_run",
        "commit"
      ],
      "default": "commit"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "options": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
